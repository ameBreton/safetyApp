<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#816D64"
    tools:context=".Generator">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#A4B396"
        android:orientation="vertical">

        <include layout="@layout/item_navigation_bar" />

        <TextView
            android:id="@+id/textView2"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/generator_title"
            android:layout_marginBottom="10dp"
            android:background="#DFE7C9"
            android:fontFamily="@font/brawler"
            android:layout_marginTop="8dp"
            android:textAlignment="center"
            android:textColor="#506634"
            android:textSize="34sp"/>

        <androidx.core.widget.NestedScrollView
            android:id="@+id/quest"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            tools:context=".Generator">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical">

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="70dp">
                    <TextView
                        android:id="@+id/textView9"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_margin="10dp"
                        android:fontFamily="@font/brawler"
                        android:text="@string/generator_text"
                        android:textSize="20sp" />
                </RelativeLayout>

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/recViewQues"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:nestedScrollingEnabled="false"
                    android:padding="10dp">

                </androidx.recyclerview.widget.RecyclerView>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="100dp"
                    android:background="@android:color/transparent" />

            </LinearLayout>


        </androidx.core.widget.NestedScrollView>
    </LinearLayout>

    <Button
        android:id="@+id/button_submit"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_margin="16dp"
        app:layout_constraintBottom_toBottomOf="parent"
        android:textColor="#506634"
        android:backgroundTint="#CBA181"
        android:fontFamily="@font/brawler"
        android:textSize="22sp"
        app:layout_constraintEnd_toEndOf="parent"
        android:text="@string/submit"/>

</androidx.constraintlayout.widget.ConstraintLayout>