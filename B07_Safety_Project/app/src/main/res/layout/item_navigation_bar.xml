<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="#816D64"
    tools:context=".HomeActivity">

    <FrameLayout
        android:layout_width="412dp"
        android:layout_height="83dp"
        android:background="#816D64"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:id="@+id/imageView"
            android:layout_width="170dp"
            android:layout_height="match_parent"
            android:layout_marginStart="5dp"
            android:layout_marginTop="0dp"
            app:srcCompat="@drawable/cscb07projlogo2" />

        <com.google.android.material.floatingactionbutton.FloatingActionButton
            android:id="@+id/floatingHome"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="200dp"
            android:layout_marginTop="15dp"
            android:clickable="true"
            android:contentDescription="@string/floatinghome"
            android:focusable="true"
            android:onClick="toHome"
            app:backgroundTint="#E1EFC0"
            app:layout_constraintStart_toEndOf="@+id/imageView"
            app:srcCompat="@drawable/cscb07projhome" />
    </FrameLayout>

    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/floatingEmergencyExit"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="15dp"
        android:layout_marginEnd="15dp"
        android:clickable="true"
        android:contentDescription="@string/floatingexit"
        android:focusable="true"
        android:onClick="Eject"
        app:backgroundTint="#CA868D"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:rippleColor="#A63636"
        app:srcCompat="@drawable/cscb07projexit2" />

    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/floatingLogout"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="15dp"
        android:layout_marginTop="15dp"
        android:layout_marginEnd="15dp"
        android:clickable="true"
        android:contentDescription="@string/floatinglogout"
        android:focusable="true"
        android:onClick="Logout"
        android:tint="#8C4A4A"
        app:backgroundTint="#E0EFBF"
        app:layout_constraintEnd_toStartOf="@+id/floatingEmergencyExit"
        app:layout_constraintTop_toTopOf="parent"
        app:srcCompat="@drawable/cscb07projlogout2" />

</androidx.constraintlayout.widget.ConstraintLayout>